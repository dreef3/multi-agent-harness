# backend/Dockerfile.wolfi
# Chainguard Wolfi variant — minimal CVE surface.
# Build context: backend/

FROM oven/bun:1 AS bun-binary

FROM cgr.dev/chainguard/node:latest-dev AS builder

USER root
WORKDIR /app

ARG CUSTOM_CA_BUNDLE=""

# Copy bun from the official image — correct arch binary, no download needed.
# Also create bunx symlink (the build script calls `bunx`).
COPY --from=bun-binary /usr/local/bin/bun /usr/local/bin/bun
RUN ln -s bun /usr/local/bin/bunx

# build-base provides make + gcc + g++ for better-sqlite3 (node-gyp)
RUN apk add --no-cache python3 build-base && \
    npm install -g node-gyp && \
    if [ -n "$CUSTOM_CA_BUNDLE" ]; then \
      echo "$CUSTOM_CA_BUNDLE" >> /etc/ssl/certs/ca-certificates.crt; \
    fi

COPY package.json bun.lock ./
RUN bun install --ignore-scripts

COPY scripts ./scripts
# Use sh — bash is not available in Chainguard minimal images
RUN sh scripts/rebuild-sqlite3.sh

COPY . .
RUN bun run build

# ---- Runtime stage ----
FROM cgr.dev/chainguard/node:latest

USER root
WORKDIR /app

COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules

RUN mkdir -p /app/data /pi-agent

ENV PI_CODING_AGENT_DIR=/pi-agent

# Chainguard images run as nonroot (UID 65532) by default
USER nonroot

CMD ["node", "dist/index.js"]
