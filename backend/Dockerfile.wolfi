# backend/Dockerfile.wolfi
# Chainguard Wolfi variant — minimal CVE surface.
# Build context: backend/

FROM cgr.dev/chainguard/node:latest-dev AS builder

USER root
WORKDIR /app

ARG BUN_VERSION=1.3.11
ARG CUSTOM_CA_BUNDLE=""

# build-base provides make + gcc + g++ in Wolfi (no separate g++ package)
RUN apk add --no-cache curl unzip python3 build-base && \
    if [ -n "$CUSTOM_CA_BUNDLE" ]; then \
      echo "$CUSTOM_CA_BUNDLE" >> /etc/ssl/certs/ca-certificates.crt; \
    fi && \
    curl -fsSL "https://github.com/oven-sh/bun/releases/download/bun-v${BUN_VERSION}/bun-linux-x64.zip" \
        -o /tmp/bun.zip && \
    unzip -q /tmp/bun.zip -d /tmp/bun-dir && \
    mv /tmp/bun-dir/bun-linux-x64/bun /usr/local/bin/bun && \
    rm -rf /tmp/bun.zip /tmp/bun-dir && \
    bun --version

COPY package.json bun.lock ./
RUN bun install --ignore-scripts

COPY scripts ./scripts
RUN bash scripts/rebuild-sqlite3.sh

COPY . .
RUN bun run build

# ---- Runtime stage ----
FROM cgr.dev/chainguard/node:latest

WORKDIR /app

COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules

RUN mkdir -p /app/data /pi-agent

ENV PI_CODING_AGENT_DIR=/pi-agent

# Chainguard images run as nonroot (UID 65532) by default
USER nonroot

CMD ["node", "dist/index.js"]
