# agents/base/Dockerfile.base.ubi
# Red Hat UBI 8 variant — uses ubi8/nodejs-22-minimal for RHEL compatibility.
# Build context: repo root (same as Dockerfile.base)

FROM registry.access.redhat.com/ubi8/nodejs-22-minimal

USER root

RUN microdnf install -y git curl tar gzip gettext && microdnf clean all

# Install GitHub CLI — download RPM directly (microdnf doesn't have config-manager)
RUN curl -fsSL "https://github.com/cli/cli/releases/download/v2.49.2/gh_2.49.2_linux_amd64.rpm" \
       -o /tmp/gh.rpm && \
    rpm -i /tmp/gh.rpm && \
    rm -f /tmp/gh.rpm

WORKDIR /app

# stdio-to-TCP bridge
COPY agents/stdio-tcp-bridge.mjs /app/stdio-tcp-bridge.mjs

# Startup wrapper for env var substitution (e.g. MCP_TOKEN in config files)
COPY agents/startup.sh /app/startup.sh
RUN chmod +x /app/startup.sh

RUN mkdir -p /workspace /agent-data

EXPOSE 3333
