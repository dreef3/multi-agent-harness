# OpenCode Agent Configuration

# Agent provider: 'pi' (default), 'opencode-zen', or 'opencode-go'
AGENT_PROVIDER=opencode-zen

# API Keys
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
OPENCODE_API_KEY=${OPENCODE_API_KEY}

# Test Repository
TEST_REPO_URL=git@github.com:dreef3/multi-agent-harness-test-repo.git

# Sub-agent configuration for OpenCode
SUB_AGENT_IMAGE=multi-agent-harness/sub-agent:latest
SUB_AGENT_NETWORK=multi-agent-harness_harness-agents

# Model configuration
MASTER_AGENT_MODEL=claude-3-opus
WORKER_AGENT_MODEL=claude-3-haiku

# Feature flags
ENABLE_OPENCODE_ZEN=true
ENABLE_OPENCODE_GO=false
