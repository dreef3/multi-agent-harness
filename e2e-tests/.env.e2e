# OpenCode Agent Configuration

# Agent provider (only 'opencode-go' is supported)
AGENT_PROVIDER=opencode-go

# Required: API Key for OpenCode Go
OPENCODE_API_KEY=${OPENCODE_API_KEY}

# Optional: API Key for Anthropic (only if using Claude fallback)
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# Test Repository
TEST_REPO_URL=git@github.com:dreef3/multi-agent-harness-test-repo.git

# Sub-agent configuration
SUB_AGENT_IMAGE=multi-agent-harness/sub-agent:latest
SUB_AGENT_NETWORK=multi-agent-harness_harness-agents

# Model configuration (used by agent provider)
MASTER_AGENT_MODEL=opencode-go
WORKER_AGENT_MODEL=opencode-go
