# GitHub Copilot provider (unlimited quota, subscription-based)
# Auth: set COPILOT_GITHUB_TOKEN — runners bootstrap auth.json automatically on startup
AGENT_PLANNING_MODEL=github-copilot/gpt-5-mini
AGENT_IMPLEMENTATION_MODEL=github-copilot/gpt-5-mini

# Test Repository
TEST_REPO_URL=git@github.com:dreef3/multi-agent-harness-test-repo.git

# Sub-agent configuration
SUB_AGENT_IMAGE=multi-agent-harness/sub-agent:latest
SUB_AGENT_NETWORK=multi-agent-harness_harness-agents
