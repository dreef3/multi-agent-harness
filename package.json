{
  "name": "multi-agent-harness",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend",
    "e2e-tests"
  ],
  "scripts": {
    "dev": "bun run --cwd backend dev & bun run --cwd frontend dev",
    "build": "bun run --cwd backend build && bun run --cwd frontend build",
    "test": "bun run --cwd backend test",
    "e2e": "bun run --cwd e2e-tests test"
  },
  "dependencies": {
    "csstype": "^3.2.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
