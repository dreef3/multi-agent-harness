ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_PATH=/run/secrets/api-key

JIRA_BASE_URL=https://jira.yourcompany.com
JIRA_TOKEN=

GITHUB_TOKEN=
BITBUCKET_BASE_URL=https://bitbucket.yourcompany.com
BITBUCKET_TOKEN=

# E2E Test Repository (optional - defaults to dreef3/multi-agent-harness-test-repo)
TEST_REPO_OWNER=dreef3
TEST_REPO_NAME=multi-agent-harness-test-repo

PORT=3000
DATA_DIR=/app/data
SUB_AGENT_IMAGE=multi-agent-harness/sub-agent:latest
SUB_AGENT_NETWORK=multi-agent-harness_harness-agents
