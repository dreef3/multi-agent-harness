# frontend/Dockerfile.ubi
# Red Hat UBI 8 variant — nginx-124 server image.
# Build context: frontend/

FROM registry.access.redhat.com/ubi8/nodejs-22 AS builder

USER root
WORKDIR /app

# Install bun for frontend build
ARG BUN_VERSION=1.3.11
RUN dnf install -y unzip && dnf clean all && \
    curl -fsSL "https://github.com/oven-sh/bun/releases/download/bun-v${BUN_VERSION}/bun-linux-x64.zip" \
        -o /tmp/bun.zip && \
    unzip -q /tmp/bun.zip -d /tmp/bun-dir && \
    mv /tmp/bun-dir/bun-linux-x64/bun /usr/local/bin/bun && \
    rm -rf /tmp/bun.zip /tmp/bun-dir

COPY package.json bun.lock* ./
RUN bun install

COPY . .
RUN bun run build

# ---- Runtime stage ----
FROM registry.access.redhat.com/ubi8/nginx-124

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

# UBI nginx-124 runs as non-root; rewrite listen port from 80 -> 8080
RUN sed -i 's/listen 80;/listen 8080;/' /etc/nginx/conf.d/default.conf

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
